{
  "name": "endless-tower2",
  "description": "A momentum roguelite: Icy Tower's power fantasy, restructured as a run-based climb.",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite --config vite/config.dev.mjs",
    "build": "vite build --config vite/config.prod.mjs",
    "preview": "vite preview --config vite/config.prod.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src",
    "format": "biome format --write src",
    "check": "npm run typecheck && npm run lint"
  },
  "dependencies": {
    "phaser": "^4.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "terser": "^5.39.0",
    "typescript": "~5.7.2",
    "vite": "^6.3.1"
  }
}
