{
  "name": "endless-tower2",
  "description": "A momentum roguelite: Icy Tower's power fantasy, restructured as a run-based climb.",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite --config vite/config.dev.mjs",
    "build": "vite build --config vite/config.prod.mjs",
    "preview": "vite preview --config vite/config.prod.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src harness tests",
    "format": "biome format --write src harness tests",
    "check": "npm run typecheck && npm run lint",
    "test": "vitest run",
    "map": "tsx harness/map.harness.ts",
    "replay": "tsx src/cli/replay.ts",
    "exam": "tsx src/cli/exam-harness.ts",
    "difficulty": "tsx harness/difficulty.harness.ts"
  },
  "dependencies": {
    "phaser": "^4.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/node": "^26.1.0",
    "terser": "^5.39.0",
    "tsx": "^4.23.0",
    "typescript": "~5.7.2",
    "vite": "^6.3.1",
    "vitest": "^4.1.10"
  }
}
